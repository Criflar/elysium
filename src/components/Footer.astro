    <div class="text-center md:text-left">
      <p class="text-lg font-extrabold text-elysium-dark tracking-tighter">Marvin Ivan Mangubat</p>
      <p class="text-xs font-bold text-elysium-text/40 tracking-widest uppercase mt-1">&copy; {currentYear} &bull; Systems Architecture</p>
    </div>

    <div class="flex items-center gap-6">
      <a href="mailto:mic.mangubat17@gmail.com" class="text-xs font-bold text-elysium-dark tracking-widest uppercase hover:text-accent-orange transition-colors">Email</a>
      <a href="https://linkedin.com/in/marvin-ivan-mangubat" target="_blank" rel="noopener noreferrer" class="text-xs font-bold text-elysium-dark tracking-widest uppercase hover:text-accent-purple transition-colors">LinkedIn</a>
      <a href="https://github.com/Criflar" target="_blank" rel="noopener noreferrer" class="text-xs font-bold text-elysium-dark tracking-widest uppercase hover:text-accent-purple transition-colors">GitHub</a>
