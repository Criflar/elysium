---
// src/components/TechnicalCapabilities.astro
---
<section id="capabilities" class="py-24 bg-white border-y border-elysium-dark/10 reveal-system opacity-0 translate-y-8 transition-all duration-700 ease-out">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex items-center gap-4 mb-12">
      <h3 class="text-xl font-extrabold text-elysium-dark uppercase tracking-widest">
        Technical Capabilities
      </h3>
      <div class="flex-grow h-px bg-elysium-dark/10"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Core Domains -->
      <div>
        <h4 class="text-xs font-bold text-accent-purple tracking-widest uppercase mb-4 border-b border-elysium-dark/10 pb-2">Core Domains</h4>
        <ul class="space-y-3 text-sm text-elysium-text font-medium">
          <li>Artificial Intelligence</li>
          <li>Machine Learning</li>
          <li>Bioinformatics</li>
          <li>Systems Design</li>
          <li>Cross-Functional Leadership</li>
        </ul>
      </div>

      <!-- Infrastructure & Logic -->
      <div>
        <h4 class="text-xs font-bold text-accent-orange tracking-widest uppercase mb-4 border-b border-elysium-dark/10 pb-2">Infrastructure</h4>
        <ul class="space-y-3 text-sm text-elysium-text font-medium">
          <li>Python & Jupyter</li>
          <li>Node.js & Express</li>
          <li>MongoDB & SQL</li>
          <li>Java</li>
          <li>C</li>
        </ul>
      </div>

      <!-- Interfaces & Deployment -->
      <div>
        <h4 class="text-xs font-bold text-elysium-dark tracking-widest uppercase mb-4 border-b border-elysium-dark/10 pb-2">Interfaces & Tools</h4>
        <ul class="space-y-3 text-sm text-elysium-text font-medium">
          <li>React & JavaScript</li>
          <li>Software Testing</li>
          <li>Git Version Control</li>
        </ul>
      </div>
    </div>
  </div>
</section>