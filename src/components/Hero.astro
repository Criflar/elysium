---
// src/components/Hero.astro
---
<section class="pt-32 pb-24 border-b border-elysium-dark/10 reveal-system opacity-0 translate-y-8 transition-all duration-700 ease-out">
  <div class="max-w-3xl">
    <h1 class="text-5xl md:text-7xl font-extrabold text-elysium-dark tracking-tighter leading-[1.1] mb-6">
      Marvin<br/><span class="text-elysium-text/50">Mangubat</span>
    </h1>

    <!--<br/><span class="text-elysium-text/50">-->
    
    <h2 class="text-lg md:text-xl font-bold text-accent-purple tracking-[0.2em] uppercase mb-8">
      AI Systems Engineer & Computational Architect
    </h2>
    
    <p class="text-lg md:text-xl text-elysium-text leading-relaxed max-w-2xl mb-12">
      Executing a disciplined roadmap toward advanced computational integration. Architecting cross-domain AI platforms (with a computational biology focus) and deploying scalable LLM analytics to build the technological foundation of the future.
    </p>
    
    <div class="flex flex-wrap items-center gap-6">
      <a href="#notable-projects" class="px-8 py-4 bg-elysium-dark text-elysium-light font-bold text-xs tracking-[0.15em] uppercase hover:bg-accent-purple transition-colors duration-300">
        Inspect Projects
      </a>
      
      <a 
        id="contact-trigger" 
        href="#" 
        data-u="mic.mangubat17" 
        data-d="gmail.com" 
        class="px-8 py-4 border border-elysium-dark text-elysium-dark font-bold text-xs tracking-[0.15em] uppercase hover:border-accent-orange hover:text-accent-orange transition-colors duration-300"
      >
        Initialize Contact
      </a>
    </div>
  </div>
</section>


<script>
  const initContact = () => {
    const trigger = document.getElementById('contact-trigger');
    if (!trigger) return;

    const executeRouting = () => {
      const username = trigger.getAttribute('data-u');
      const domain = trigger.getAttribute('data-d');
      
      if (username && domain) {
        trigger.setAttribute('href', `mailto:${username}@${domain}`);
      }
    };

    trigger.addEventListener('mouseenter', executeRouting);
    trigger.addEventListener('click', executeRouting);
  };

  document.addEventListener('astro:page-load', initContact);
</script>