---
// src/components/RecentProjects.astro
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// Fetch, filter for featured, and sort descending
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((project: CollectionEntry<'projects'>) => project.data.featured)
  .sort((a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) => b.data.year.localeCompare(a.data.year));

// Asynchronous rendering resolution (Astro 5.0 standard)
const renderedFeaturedProjects = await Promise.all(
  featuredProjects.map(async (project: CollectionEntry<'projects'>) => {
    const { Content } = await render(project); 
    return { project, Content };
  })
);
---
<section id="recent-projects" class="py-24">
  <div class="max-w-3xl mx-auto px-6">
    
    <div class="flex items-center justify-between mb-12">
      <div class="flex items-center gap-4 flex-grow">
        <h3 class="text-2xl font-extrabold text-elysium-dark uppercase tracking-widest">
          Recent Projects
        </h3>
        <div class="flex-grow h-px bg-elysium-dark/10 mr-6"></div>
      </div>
      
      <a href="/archive" class="group flex items-center gap-2 text-xs font-bold text-elysium-dark tracking-[0.15em] uppercase hover:text-accent-purple transition-colors duration-300 whitespace-nowrap">
        <span>Full Archive</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="space-y-6 mb-16">
      
      {renderedFeaturedProjects.map(({ project, Content }) => (
        <article class="group relative border border-elysium-dark/10 bg-white p-8 hover:border-accent-orange transition-colors duration-300">
          
          <a 
            href={project.data.link || `/archive#${project.id}`} 
            target={project.data.link ? "_blank" : "_self"}
            rel={project.data.link ? "noopener noreferrer" : ""}
            class="absolute inset-0 z-10" 
            aria-label={`View ${project.data.title}`}
          ></a>
          
          <div class="flex justify-between items-start mb-4 relative z-20 pointer-events-none">
            <div>
              <h4 class="text-xl font-bold text-elysium-dark mb-1 group-hover:text-accent-orange transition-colors duration-300">
                {project.data.title}
              </h4>
              <p class="text-xs font-bold text-accent-purple tracking-widest uppercase">
                {project.data.category} • {project.data.subcategory}
              </p>
            </div>
            <span class="text-xs font-bold text-elysium-text/40 tracking-widest">{project.data.year}</span>
          </div>
          
          <div class="text-sm text-elysium-text leading-relaxed mb-6 relative z-20 pointer-events-none prose prose-sm prose-p:my-0">
            <Content />
          </div>
          
          <div class="flex flex-wrap gap-2 relative z-20 pointer-events-none">
            {project.data.tags.map((tag: string) => (
              <span class="px-3 py-1 border border-elysium-dark/20 text-[10px] font-bold tracking-wider uppercase text-elysium-dark">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}

    </div>

  </div>
</section>