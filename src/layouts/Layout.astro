---
// src/layouts/Layout.astro
import { ClientRouter } from 'astro:transitions'; // <-- Updated for Astro 5.0
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Elysium | Systems Architecture</title>
    
    <ClientRouter />
  </head>
  <body class="bg-elysium-light text-elysium-text relative min-h-screen selection:bg-accent-purple selection:text-white font-sans">
    
    <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.075]" 
         style="background-image: url('/noise.svg');">
    </div>

    <main class="relative z-10 max-w-4xl mx-auto px-6 py-20">
      <slot />
    </main>

  </body>
</html>